# ========================================
# Vercel 环境变量配置指南
# ========================================
# 
# 在 Vercel 部署前，需要配置以下环境变量
# 访问：https://vercel.com/dashboard → 你的项目 → Settings → Environment Variables
#
# ========================================
# 必须配置的环境变量
# ========================================

# Supabase 配置（必填）
NEXT_PUBLIC_SUPABASE_URL=https://bgpeyfvgqpgsezgzqrco.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_N3tR08CEY_iXD8HcgnM-9Q_YTUfdECP

# 网站名称（必填）
NEXT_PUBLIC_SITE_NAME=淋淋园牛羊肉

# ========================================
# 可选配置的环境变量
# ========================================

# 订购平台链接（可选，根据实际需求修改）
NEXT_PUBLIC_WECHAT_MINIPROGRAM_URL=https://your-wechat-miniprogram.com
NEXT_PUBLIC_MEITUAN_URL=https://meituan.com/your-store
NEXT_PUBLIC_ELEME_URL=https://ele.me/your-store

# 生产环境域名（可选，绑定自定义域名后配置）
NEXT_PUBLIC_SITE_URL=https://huanglaoban.com

# ========================================
# 配置步骤
# ========================================
#
# 1. 登录 Vercel Dashboard
#    https://vercel.com/dashboard
#
# 2. 选择或创建项目
#
# 3. 进入 Settings → Environment Variables
#
# 4. 点击 "Add Environment Variable"
#
# 5. 添加上述所有必须的变量
#    - Name: 变量名（例如：NEXT_PUBLIC_SUPABASE_URL）
#    - Value: 变量值
#    - Environment: 勾选 Production, Preview, Development
#
# 6. 保存后重新部署项目
#
# ========================================
# 注意事项
# ========================================
#
# ⚠️ 所有 NEXT_PUBLIC_ 开头的变量会暴露给浏览器
#    不要存放敏感信息（如数据库密码、Secret Key 等）
#
# ⚠️ Supabase 的 Anon Key 是公开的，可以安全使用
#    Service Role Key 绝对不能放在环境变量中！
#
# ⚠️ 修改环境变量后需要重新部署才能生效
#    vercel --prod 或在 Dashboard 点击 "Redeploy"
#
# ========================================
# 本地测试
# ========================================
#
# 在本地开发时，将变量添加到 .env.local 文件：
#
# cp .env.local.example .env.local
# # 然后编辑 .env.local 填入实际的值
#
# 启动开发服务器：
# npm run dev
#
# ========================================
